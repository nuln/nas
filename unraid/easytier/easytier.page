  <input type="button" value="Restart" onclick="doAction('restart')">
  <input type="button" value="Refresh" onclick="refresh()">
  <span id="et-status" style="margin-left:8px;font-size:12px;color:#888;"></span>
</td></tr></table>
</div>

<hr style="clear:both; margin:12px 0;">

<table class="unraid tablesorter"><thead><tr><td>Network Configuration</td></tr></thead></table>

<form method="POST" action="/update.php" target="progressFrame">
<dl>
  <dt>Network Name</dt>
  <dd><input type="text" id="et-name" value="easytier"></dd>
</dl>
<blockquote class="inline_help">All nodes must use the same network name.</blockquote>

<dl>
  <dt>Network Secret</dt>
  <dd><input type="password" id="et-secret" placeholder="Leave blank"></dd>
</dl>
<blockquote class="inline_help">Password for the network.</blockquote>

<dl>
  <dt>Virtual IPv4</dt>
  <dd><input type="text" id="et-ipv4" placeholder="10.144.144.1/24"></dd>
</dl>
<blockquote class="inline_help">Static IP. Leave empty for DHCP.</blockquote>

<dl>
  <dt>Hostname</dt>
  <dd><input type="text" id="et-host"></dd>
</dl>
<blockquote class="inline_help">Node display name.</blockquote>

<dl>
  <dt>Peer URLs</dt>
  <dd><input type="text" id="et-peers" placeholder="tcp://host:11010"></dd>
</dl>
<blockquote class="inline_help">Comma-separated peer addresses.</blockquote>

<dl>
  <dt>Listener URLs</dt>
  <dd><input type="text" id="et-listeners" value="tcp://0.0.0.0:11010, udp://0.0.0.0:11010"></dd>
</dl>
<blockquote class="inline_help">Addresses to listen on.</blockquote>

<dl>
  <dt>Proxy CIDRs</dt>
  <dd><input type="text" id="et-proxy" placeholder="192.168.1.0/24"></dd>
</dl>
<blockquote class="inline_help">Subnets reachable via this node.</blockquote>

<dl>
  <dt>Save</dt>
  <dd><span><input type="button" id="et-save" value="Apply"></span></dd>
</dl>
<div id="et-cfg-msg" style="margin-top:4px;font-size:12px;color:#888;"></div>
</form>

<script>
const api = '<?= $pluginPath; ?>/api.php';
function request(a, m, p) {
  return new Promise(function(r, j) {
    var o = { method: m || 'GET' };
    if (p) { o.headers = {'Content-Type':'application/json'}; o.body = JSON.stringify(p); }
    fetch(api+'?action='+encodeURIComponent(a), o)
      .then(function(x){return x.json()})
      .then(function(x){if(x.success) r(x); else j(new Error(x.error||'Failed'))})
      .catch(j);
  });
}
function refresh() {
  request('status').then(function(r) {
    document.getElementById('et-status').textContent = r.data.running === '1' ? 'Running' : 'Stopped';
  }).catch(function(){});
  request('node_info').then(function(r) {
    var d = r.data || {};
    var h = '';
    [['Hostname',d.hostname||'-'],['Peer ID',String(d.peer_id||'-')],['Version',d.version||'-'],['Proxy CIDRs',(d.proxy_cidrs||[]).join(', ')||'None']]
      .forEach(function(v,i){h+='<tr class="'+(i%2===0?'normal-row':'alt-row')+'"><td>'+v[0]+'</td><td>'+v[1]+'</td></tr>'});
    document.getElementById('et-node-info').innerHTML = h;
  }).catch(function(){});
  request('peers').then(function(r) {
    var d = r.data || [];
    if (!d.length) { document.getElementById('et-peers-content').innerHTML = '<tr><td colspan="4">No peers</td></tr>'; return; }
    var h = '';
    d.forEach(function(p,i) {
      var t = p.tunnel_proto || p.cost || '-';
      h += '<tr class="'+(i%2===0?'normal-row':'alt-row')+'"><td>'+(p.hostname||p.id||'-')+'</td><td>'+t+'</td><td>'+(p.lat_ms&&p.lat_ms!=='-'?p.lat_ms+'ms':'-')+'</td><td>'+(p.loss_rate||'-')+'</td></tr>';
    });
    document.getElementById('et-peers-content').innerHTML = h;
  }).catch(function(){});
  request('routes').then(function(r) {
    var d = r.data || [];
    if (!d.length) { document.getElementById('et-routes-content').innerHTML = '<tr><td colspan="4">No routes</td></tr>'; return; }
    var h = '';
    d.forEach(function(r,i) {
      h += '<tr class="'+(i%2===0?'normal-row':'alt-row')+'"><td>'+(r.hostname||'-')+'</td><td>'+(r.proxy_cidrs||'-')+'</td><td>'+(r.next_hop_hostname||'-')+'</td><td>'+(r.next_hop_lat!=null?r.next_hop_lat.toFixed(2)+'ms':'-')+'</td></tr>';
    });
    document.getElementById('et-routes-content').innerHTML = h;
  }).catch(function(){});
}
function doAction(a) { request(a,'POST').then(refresh).catch(function(){}); }
document.getElementById('et-save').addEventListener('click', function() {
  var m = document.getElementById('et-cfg-msg');
  request('save_config','POST',{
    network_name: document.getElementById('et-name').value.trim(),
    network_secret: document.getElementById('et-secret').value,
    virtual_ipv4: document.getElementById('et-ipv4').value.trim(),
    hostname: document.getElementById('et-host').value.trim(),
    peer_urls: document.getElementById('et-peers').value.trim(),
    listener_urls: document.getElementById('et-listeners').value.trim(),
    proxy_cidrs: document.getElementById('et-proxy').value.trim()
  }).then(function(){m.textContent='Saved.';m.style.color='#5cb85c';}).catch(function(e){m.textContent=e.message;m.style.color='#d9534f';});
});
refresh();
</script>
