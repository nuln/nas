<script>
const api = '<?=$pluginPath;?>/api.php';

function switchTab(name) {
  document.querySelectorAll('.tab').forEach(function(t) { t.classList.remove('active'); });
  document.querySelectorAll('.tab-panel').forEach(function(p) { p.classList.remove('active'); });
  document.querySelectorAll('.tab').forEach(function(t) {
    if (t.textContent.trim().toLowerCase() === name) t.classList.add('active');
  });
  document.getElementById('panel-' + name).classList.add('active');
  if (name === 'manage') renderManage();
}

function request(action, method, payload) {
  return new Promise(function(resolve, reject) {
    var opts = { method: method || 'GET' };
    if (payload) {
      opts.headers = { 'Content-Type': 'application/json' };
      opts.body = JSON.stringify(payload);
    }
    fetch(api + '?action=' + encodeURIComponent(action), opts)
      .then(function(r) { return r.json(); })
      .then(function(j) { if (j.success) resolve(j); else reject(new Error(j.error || 'Failed')); })
      .catch(reject);
  });
}

function refresh() {
  request('node_info').then(function(r) {
    var d = r.data || {};
    var rows = '';
    [['Hostname',d.hostname||'-'],['Peer ID',String(d.peer_id||'-')],['Version',d.version||'-'],['Proxy CIDRs',(d.proxy_cidrs||[]).join(', ')||'None']]
      .forEach(function(item,i) { rows += '<tr class="'+(i%2===0?'normal-row':'alt-row')+'"><td>'+item[0]+'</td><td>'+item[1]+'</td></tr>'; });
    document.getElementById('et-node-info').innerHTML = rows;
  }).catch(function() {
    document.getElementById('et-node-info').innerHTML = '<tr><td colspan="2">Failed to load</td></tr>';
  });

  request('peers').then(function(r) {
    var data = r.data || [];
    if (!data.length) { document.getElementById('et-peers-content').innerHTML = '<tr><td colspan="7">No peers</td></tr>'; return; }
    var rows = '';
    data.forEach(function(p,i) {
      var tt = p.tunnel_proto || p.cost || '-';
      var badge = (tt==='p2p'||tt==='tcp'||tt==='udp')?'badge-ok':'badge-warn';
      rows += '<tr class="'+(i%2===0?'normal-row':'alt-row')+'"><td><strong>'+(p.hostname||p.id||'-')+'</strong></td><td><span class="badge '+badge+'">'+tt+'</span></td>'+
        '<td>'+(p.lat_ms&&p.lat_ms!=='-'?p.lat_ms+'ms':'-')+'</td><td>'+(p.loss_rate||'-')+'</td></tr>';
    });
    document.getElementById('et-peers-content').innerHTML = rows;
  }).catch(function() {
    document.getElementById('et-peers-content').innerHTML = '<tr><td colspan="7">Failed</td></tr>';
  });

  request('routes').then(function(r) {
    var data = r.data || [];
    if (!data.length) { document.getElementById('et-routes-content').innerHTML = '<tr><td colspan="5">No routes</td></tr>'; return; }
    var rows = '';
    data.forEach(function(r,i) {
      rows += '<tr class="'+(i%2===0?'normal-row':'alt-row')+'"><td><strong>'+(r.hostname||'-')+'</strong></td>'+
        '<td>'+(r.proxy_cidrs||'-')+'</td><td>'+(r.next_hop_hostname||'-')+'</td>'+
        '<td>'+(r.next_hop_lat!=null?r.next_hop_lat.toFixed(2)+'ms':'-')+'</td><td>'+(r.path_len!=null?r.path_len:'-')+'</td></tr>';
    });
    document.getElementById('et-routes-content').innerHTML = rows;
  }).catch(function() {
    document.getElementById('et-routes-content').innerHTML = '<tr><td colspan="5">Failed</td></tr>';
  });

  request('logs').then(function(r) {
    document.getElementById('et-log').value = (r.data&&r.data.logs)?r.data.logs:'';
  }).catch(function(){});
}

function renderManage() {
  request('connector_list').then(function(r) {
    var list = Array.isArray(r.data)?r.data:[];
    if (!list.length) { document.getElementById('et-conn-list').innerHTML = '<tr><td>No connectors</td></tr>'; return; }
    var h = '<table class="unraid statusTable" style="margin:0"><thead><tr><th>URL</th><th></th></tr></thead><tbody>';
    list.forEach(function(c) { var u=c.url||c; h+='<tr><td>'+u+'</td><td><input type="button" value="Remove" onclick="removeConnector(\''+String(u).replace(/'/g,"\\'")+'\')"></td></tr>'; });
    h += '</tbody></table>';
    document.getElementById('et-conn-list').innerHTML = h;
  }).catch(function(){});
}

window.addConnector = function() {
  var url = document.getElementById('et-conn-url').value.trim();
  var msg = document.getElementById('et-conn-msg');
  if (!url) { msg.textContent='Enter URL'; msg.className='msg err'; return; }
  request('connector_add','POST',{url:url}).then(function(){ msg.textContent='Added'; msg.className='msg ok'; document.getElementById('et-conn-url').value=''; renderManage(); })
    .catch(function(e){ msg.textContent=e.message; msg.className='msg err'; });
};
window.removeConnector = function(url) {
  request('connector_remove','POST',{url:url}).then(function(){ document.getElementById('et-conn-msg').textContent='Removed'; document.getElementById('et-conn-msg').className='msg ok'; renderManage(); })
    .catch(function(e){ document.getElementById('et-conn-msg').textContent=e.message; document.getElementById('et-conn-msg').className='msg err'; });
};
window.addPortForward = function() {
  var p=document.getElementById('et-pf-proto').value, b=document.getElementById('et-pf-bind').value.trim(), d=document.getElementById('et-pf-dst').value.trim(), m=document.getElementById('et-pf-msg');
  if(!b||!d){m.textContent='Fill both fields';m.className='msg err';return;}
  request('portforward_add','POST',{proto:p,bind:b,dst:d}).then(function(){m.textContent='Added';m.className='msg ok';document.getElementById('et-pf-bind').value='';document.getElementById('et-pf-dst').value='';}).catch(function(e){m.textContent=e.message;m.className='msg err';});
};
window.setLogLevel = function() {
  var l=document.getElementById('et-log-level').value;
  request('logger_set','POST',{level:l}).then(function(){document.getElementById('et-logger-msg').textContent='Set to '+l;document.getElementById('et-logger-msg').className='msg ok';}).catch(function(e){document.getElementById('et-logger-msg').textContent=e.message;document.getElementById('et-logger-msg').className='msg err';});
};

document.getElementById('et-save').addEventListener('click',function(){
  var m=document.getElementById('et-cfg-msg');
  request('save_config','POST',{network_name:document.getElementById('et-name').value.trim(),network_secret:document.getElementById('et-secret').value,virtual_ipv4:document.getElementById('et-ipv4').value.trim(),hostname:document.getElementById('et-host').value.trim(),peer_urls:document.getElementById('et-peers').value.trim(),listener_urls:document.getElementById('et-listeners').value.trim(),proxy_cidrs:document.getElementById('et-proxy').value.trim()})
    .then(function(){m.textContent='Configuration saved.';m.className='msg ok';}).catch(function(e){m.textContent=e.message;m.className='msg err';});
});
document.getElementById('et-start').addEventListener('click',function(){request('start','POST').then(refresh);});
document.getElementById('et-stop').addEventListener('click',function(){request('stop','POST').then(refresh);});
document.getElementById('et-restart').addEventListener('click',function(){request('restart','POST').then(refresh);});
document.getElementById('et-refresh').addEventListener('click',refresh);

refresh();
setInterval(refresh,10000);
</script>
