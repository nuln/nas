</div>

<script>
const api = '<?=$pluginPath;?>/api.php';

document.querySelector('.tabs').addEventListener('click', function(e) {
  var t = e.target.closest('.tab');
  if (!t) return;
  document.querySelectorAll('.tab').forEach(function(x){x.classList.remove('active')});
  document.querySelectorAll('.tab-panel').forEach(function(x){x.classList.remove('active')});
  t.classList.add('active');
  document.getElementById('panel-'+t.dataset.tab).classList.add('active');
  if (t.dataset.tab === 'manage') renderManage();
});

function request(a, m, p) {
  return new Promise(function(r, j) {
    var o = { method: m || 'GET' };
    if (p) { o.headers = {'Content-Type':'application/json'}; o.body = JSON.stringify(p); }
    fetch(api+'?action='+encodeURIComponent(a), o)
      .then(function(x){return x.json()})
      .then(function(x){if(x.success) r(x); else j(new Error(x.error||'Failed'))})
      .catch(j);
  });
}

function refresh() {
  request('status').then(function(r) {
    var s = r.data.running === '1' ? 'Running' : 'Stopped';
    document.getElementById('et-status').textContent = s;
  }).catch(function(){});

  request('node_info').then(function(r) {
    var d = r.data || {};
    var h = '';
    [['Hostname',d.hostname||'-'],['Peer ID',String(d.peer_id||'-')],['Version',d.version||'-'],['Proxy CIDRs',(d.proxy_cidrs||[]).join(', ')||'None']]
      .forEach(function(v,i){h+='<tr class="'+(i%2===0?'normal-row':'alt-row')+'"><td>'+v[0]+'</td><td>'+v[1]+'</td></tr>'});
    document.getElementById('et-node-info').innerHTML = h;
  }).catch(function(){});

  request('peers').then(function(r) {
    var d = r.data || [];
    if (!d.length) { document.getElementById('et-peers-content').innerHTML = '<tr><td colspan="4">No peers</td></tr>'; return; }
    var h = '';
    d.forEach(function(p,i) {
      var t = p.tunnel_proto || p.cost || '-';
      h += '<tr class="'+(i%2===0?'normal-row':'alt-row')+'"><td>'+(p.hostname||p.id||'-')+'</td><td>'+t+'</td><td>'+(p.lat_ms&&p.lat_ms!=='-'?p.lat_ms+'ms':'-')+'</td><td>'+(p.loss_rate||'-')+'</td></tr>';
    });
    document.getElementById('et-peers-content').innerHTML = h;
  }).catch(function(){});

  request('routes').then(function(r) {
    var d = r.data || [];
    if (!d.length) { document.getElementById('et-routes-content').innerHTML = '<tr><td colspan="4">No routes</td></tr>'; return; }
    var h = '';
    d.forEach(function(r,i) {
      h += '<tr class="'+(i%2===0?'normal-row':'alt-row')+'"><td>'+(r.hostname||'-')+'</td><td>'+(r.proxy_cidrs||'-')+'</td><td>'+(r.next_hop_hostname||'-')+'</td><td>'+(r.next_hop_lat!=null?r.next_hop_lat.toFixed(2)+'ms':'-')+'</td></tr>';
    });
    document.getElementById('et-routes-content').innerHTML = h;
  }).catch(function(){});

  request('logs').then(function(r) {
    document.getElementById('et-log').value = (r.data&&r.data.logs)?r.data.logs:'';
  }).catch(function(){});
}

function doAction(a) {
  request(a,'POST').then(refresh).catch(function(){});
}

function renderManage() {
  request('connector_list').then(function(r) {
    var l = Array.isArray(r.data)?r.data:[];
    if (!l.length) { document.getElementById('et-conn-list').innerHTML = '<tr><td>No connectors</td></tr>'; return; }
    var h = '<table class="unraid statusTable" style="margin:0"><thead><tr><th>URL</th><th></th></tr></thead><tbody>';
    l.forEach(function(c){var u=c.url||c; h+='<tr><td>'+u+'</td><td><input type="button" value="Remove" onclick="removeConnector(\''+String(u).replace(/'/g,"\\'")+'\')"></td></tr>'});
    h += '</tbody></table>';
    document.getElementById('et-conn-list').innerHTML = h;
  }).catch(function(){});
}

window.addConnector = function() {
  var u = document.getElementById('et-conn-url').value.trim();
  var m = document.getElementById('et-conn-msg');
  if (!u) { m.textContent='Enter URL'; return; }
  request('connector_add','POST',{url:u}).then(function(){m.textContent='Added'; document.getElementById('et-conn-url').value=''; renderManage();}).catch(function(e){m.textContent=e.message;});
};

window.removeConnector = function(u) {
  request('connector_remove','POST',{url:u}).then(function(){document.getElementById('et-conn-msg').textContent='Removed'; renderManage();}).catch(function(e){document.getElementById('et-conn-msg').textContent=e.message;});
};

window.setLogLevel = function() {
  var l = document.getElementById('et-log-level').value;
  request('logger_set','POST',{level:l}).then(function(){document.getElementById('et-logger-msg').textContent='Set to '+l;}).catch(function(e){document.getElementById('et-logger-msg').textContent=e.message;});
};

document.getElementById('et-save').addEventListener('click', function() {
  var m = document.getElementById('et-cfg-msg');
  request('save_config','POST',{
    network_name: document.getElementById('et-name').value.trim(),
    network_secret: document.getElementById('et-secret').value,
    virtual_ipv4: document.getElementById('et-ipv4').value.trim(),
    hostname: document.getElementById('et-host').value.trim(),
    peer_urls: document.getElementById('et-peers').value.trim(),
    listener_urls: document.getElementById('et-listeners').value.trim(),
    proxy_cidrs: document.getElementById('et-proxy').value.trim()
  }).then(function(){m.textContent='Saved.';m.style.color='#5cb85c';}).catch(function(e){m.textContent=e.message;m.style.color='#d9534f';});
});

refresh();
setInterval(refresh, 10000);
</script>
