<?xml version='1.0' standalone='yes'?>
<!DOCTYPE PLUGIN [
  <!ENTITY name      "easytier">
  <!ENTITY author    "nuln">
  <!ENTITY version   "2026.06.07">
]>

<PLUGIN name="&name;" author="&author;" version="&version;" pluginURL="https://raw.githubusercontent.com/nuln/nas/master/unraid/easytier/easytier.plg" min="6.9.0" support="https://github.com/nuln/nas">

<CHANGES>
<![CDATA[
###2026.06.07
- Upgrade easytier to v2.6.4
- Remove easytier-web-embed dependency
- Use easytier-cli for status
- Tailscale-style settings page
]]>
</CHANGES>

<FILE Name="/boot/config/plugins/easytier/easytier-2026.06.07.tgz" Run="installpkg">
<URL>https://github.com/nuln/nas/raw/master/unraid/easytier/easytier-2026.06.07.tgz</URL>
</FILE>

<FILE Name="/boot/config/plugins/easytier/rc.easytier">
<URL>https://raw.githubusercontent.com/nuln/nas/master/unraid/easytier/rc.easytier</URL>
</FILE>

<FILE Name="/etc/rc.d/rc.easytier">
<LOCAL>/boot/config/plugins/easytier/rc.easytier</LOCAL>
</FILE>

<FILE Name="/boot/config/plugins/easytier/event.disks_mounted">
<URL>https://raw.githubusercontent.com/nuln/nas/master/unraid/easytier/event.disks_mounted</URL>
</FILE>

<FILE Name="/usr/local/emhttp/plugins/easytier/easytier.page">
<URL>https://raw.githubusercontent.com/nuln/nas/master/unraid/easytier/easytier.page</URL>
</FILE>

<FILE Name="/usr/local/emhttp/plugins/easytier/api.php">
<URL>https://raw.githubusercontent.com/nuln/nas/master/unraid/easytier/api.php</URL>
</FILE>

<FILE Name="/usr/local/emhttp/plugins/easytier/style.css">
<URL>https://raw.githubusercontent.com/nuln/nas/master/unraid/easytier/style.css</URL>
</FILE>

<FILE Name="/boot/config/plugins/easytier/icon.png">
<URL>https://raw.githubusercontent.com/nuln/nas/master/unraid/easytier/logo.png</URL>
</FILE>

<FILE Name="/usr/local/emhttp/plugins/easytier/images/easytier.png">
<LOCAL>/boot/config/plugins/easytier/icon.png</LOCAL>
</FILE>

<FILE Run="/bin/bash">
<INLINE>
<![CDATA[
chmod +x /etc/rc.d/rc.easytier 2>/dev/null || true

if [ ! -f /boot/config/plugins/easytier/easytier.conf ]; then
cat > /boot/config/plugins/easytier/easytier.conf <<EOF
NETWORK_NAME="easytier"
NETWORK_SECRET=""
DHCP="yes"
VIRTUAL_IPV4=""
HOSTNAME=""
PEER_URLS=""
LISTENER_URLS="tcp://0.0.0.0:11010, udp://0.0.0.0:11010"
PROXY_CIDRS=""
AUTOSTART="yes"
EOF
fi
]]>
</INLINE>
</FILE>

<FILE Run="/bin/bash" Method="remove">
<INLINE>
<![CDATA[
removepkg easytier-2026.06.07
rm -f /etc/rc.d/rc.easytier
rm -rf /usr/local/emhttp/plugins/easytier
rm -f /boot/config/plugins/easytier/easytier-*.tgz
]]>
</INLINE>
</FILE>

</PLUGIN>
